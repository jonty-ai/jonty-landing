# Site URL for SEO metadata
NEXT_PUBLIC_SITE_URL=https://askjonty.ai

# Formspree form ID for email capture
NEXT_PUBLIC_FORMSPREE_ID=xxxxxx

# Pilot access password (server-side only — do NOT prefix with NEXT_PUBLIC_)
PILOT_ACCESS_PASSWORD=change-me

# Platform endpoints (server-side only — do NOT prefix with NEXT_PUBLIC_)
# Include the full URL with path, e.g. https://example.com/some/path
PLATFORM_REGISTER_URL=http://localhost:3000/change-me
PLATFORM_VERIFY_OTP_URL=http://localhost:3000/change-me
